# Pre-IPO Compliance Gate — Environment Variables

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# AWS
AWS_REGION=us-east-1
S3_AUDIT_BUCKET=pre-ipo-compliance-audit
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:pre-ipo-compliance-alerts

# Lambda Function URLs (after deployment)
LAMBDA_LICENSE_SCANNER_URL=https://xxx.lambda-url.us-east-1.on.aws/
LAMBDA_SECRETS_SCANNER_URL=https://xxx.lambda-url.us-east-1.on.aws/
LAMBDA_PR_REPORTER_URL=https://xxx.lambda-url.us-east-1.on.aws/

# API Gateway (webhook endpoint)
API_GATEWAY_URL=https://xxx.execute-api.us-east-1.amazonaws.com/prod/compliance

# Airia
AIRIA_PIPELINE_ID=7bd49707-e2a1-4ddb-a246-455cbc75960d

# Optional: GCP alternatives
# GCS_AUDIT_BUCKET=pre-ipo-compliance-audit
# PUBSUB_TOPIC=projects/your-project/topics/compliance-alerts
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
